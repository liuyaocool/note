[{
	"output": "DP-1",
	"modules-left": [
		"hyprland/workspaces",
		"hyprland/window"
	],
	"modules-center": [],
	"modules-right": [
		"network",
		"cpu",
		"memory",
		"custom/clock"
	],
	"hyprland/window": {
		"format": "{}",
		"separate-outputs": true
	},
	"hyprland/workspaces": {
		"format": "{icon}",
		"format-icons": {
			"11": "1",
			"12": "2",
			"13": "3",
			"14": "4",
			"15": "5",
			"16": "6",
			"17": "7",
			"18": "8",
			"19": "9",
			"20": "10"
		}
	},
	"clock": {
        "format": "{:%A, %B %d, %Y (%V) | %r}",
        "format-alt": "{:%a, %b %d, %Y | %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },
	"memory": {
		"format": "M {used:0.1f}/{total:0.1f}",
        "interval": 1
    },
	"cpu": {
        "format": "C {usage}%",
        "interval": 1
    },
	"network": {
        "format-wifi": "{essid} ({signalStrength}%) ↟{bandwidthUpBytes} ↡{bandwidthDownBytes}",
        "format-ethernet": "↑{bandwidthUpBytes} ↓{bandwidthDownBytes}", 
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected",
        "interval": 1
    },
	"custom/network": {
        "format-wifi": "{essid} ({signalStrength}%) ↟{bandwidthUpBytes} ↡{bandwidthDownBytes}",
        "format-ethernet": "↟{bandwidthUpBytes} ↡{bandwidthDownBytes} {ipaddr}/{cidr}", 
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected",
        "format-alt": "",
        "interval": 1
    },
	"custom/clock": {
        "format": " {} ",
        "escape": true,
        "interval": 1,
        "tooltip": true,
        "exec": "date '+%u  %m/%d %H:%M:%S'"
    }
},{
	"output": "HDMI-A-2",
   	"modules-left": [
